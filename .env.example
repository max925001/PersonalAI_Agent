# Core Settings
APP_NAME="AI Shivam"
APP_ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY="your-jwt-secret-key-change-in-production"

# MongoDB Database URL
MONGO_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/"
MONGO_DB_NAME="ai_twin_db"

# Cache & Vector Store
REDIS_URL="redis://localhost:6379/0"
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_URL="https://<cluster-endpoint>.cloud.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"
QDRANT_COLLECTION_NAME="shivam_knowledge_base"

# External AI Integrations
GROQ_API_KEY="your-groq-api-key"
GOOGLE_API_KEY="your-google-api-key"
MISTRALAI_API_KEY="your-mistral-api-key"

# ElevenLabs Integration (Alternative Voice Synthesis)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="your-voice-id"
ELEVENLABS_STABILITY=0.4
ELEVENLABS_SIMILARITY_BOOST=0.85

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# GitHub Integration
GITHUB_TOKEN="your-github-personal-access-token"

# Legacy / S3 Fallback
S3_BUCKET_NAME="your-s3-bucket-name"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION_NAME="us-east-1"

# Twilio Configuration
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
PUBLIC_URL="https://your-ngrok-subdomain.ngrok-free.app"
FRONTEND_URL="https://your-frontend-domain.vercel.app"
